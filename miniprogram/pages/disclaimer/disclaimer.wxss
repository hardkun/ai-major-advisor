.legal-page {
  padding-top: 0;
}

.legal-hero {
  margin: 0 -28rpx 28rpx;
  padding: 48rpx 40rpx 44rpx;
  border-radius: 0 0 34rpx 34rpx;
  background: linear-gradient(145deg, #123b70, #1769aa);
  color: #ffffff;
}

.hero-label {
  color: rgba(255, 255, 255, 0.62);
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 43rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 25rpx;
}

.important-notice {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #f0d9a7;
  border-radius: 15rpx;
  background: #fff8e8;
  color: #73541a;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.75;
}

.terms-card {
  padding: 8rpx 30rpx;
}

.term-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.term-item:last-child {
  border-bottom: none;
}

.term-number {
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #e7f2ff;
  color: #1769aa;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
}

.term-text {
  flex: 1;
  color: #526377;
  font-size: 27rpx;
  line-height: 1.9;
  text-align: justify;
}

.home-button {
  width: 100%;
  margin-top: 34rpx;
}

