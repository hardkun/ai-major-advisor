.legal-page {
  padding-top: 0;
}

.legal-hero {
  margin: 0 -28rpx 28rpx;
  padding: 48rpx 40rpx 44rpx;
  border-radius: 0 0 34rpx 34rpx;
  background: linear-gradient(145deg, #123b70, #1769aa);
  color: #ffffff;
}

.hero-label {
  color: rgba(255, 255, 255, 0.62);
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 43rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 25rpx;
  line-height: 1.65;
}

.privacy-card {
  padding: 4rpx 30rpx;
}

.privacy-item {
  display: flex;
  align-items: flex-start;
  padding: 29rpx 0;
  border-bottom: 1rpx solid #edf1f5;
}

.privacy-item:last-child {
  border-bottom: none;
}

.item-mark {
  flex-shrink: 0;
  width: 55rpx;
  margin-right: 18rpx;
  color: #83a8c9;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.item-content {
  flex: 1;
}

.item-title {
  color: #17395f;
  font-size: 28rpx;
  font-weight: 700;
}

.item-text {
  margin-top: 11rpx;
  color: #526377;
  font-size: 27rpx;
  line-height: 1.85;
  text-align: justify;
}

.privacy-note {
  margin-top: 26rpx;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
  background: #eef6fd;
  color: #466984;
  font-size: 24rpx;
  line-height: 1.7;
}

.home-button {
  width: 100%;
  margin-top: 34rpx;
}

