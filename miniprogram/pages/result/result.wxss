.result-page {
  padding-top: 0;
}

.result-hero {
  margin: 0 -28rpx 30rpx;
  padding: 48rpx 40rpx 42rpx;
  border-radius: 0 0 34rpx 34rpx;
  background: linear-gradient(145deg, #123b70, #1769aa);
  color: #ffffff;
}

.result-title {
  font-size: 43rpx;
  font-weight: 700;
}

.result-subtitle {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
  line-height: 1.7;
}

.report-id-badge {
  display: inline-block;
  margin-top: 24rpx;
  padding: 8rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
}

.result-count {
  margin: 0 8rpx 20rpx;
  color: #6e7e91;
  font-size: 24rpx;
}

.recommend-card {
  padding: 32rpx 30rpx;
}

.card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.school-area {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.school-name {
  color: #17395f;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.major-name {
  margin-top: 9rpx;
  color: #53657a;
  font-size: 27rpx;
}

.match-tag {
  flex-shrink: 0;
  min-width: 58rpx;
  padding: 9rpx 15rpx;
  border-radius: 11rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.match-steady {
  background: #e7f2ff;
  color: #1769aa;
}

.match-safe {
  background: #e8f7ee;
  color: #24824a;
}

.match-rush {
  background: #fff2e5;
  color: #d8731c;
}

.match-default {
  background: #eef1f5;
  color: #5f6f82;
}

.basic-info {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rpx;
  overflow: hidden;
  border-radius: 14rpx;
  background: #e8edf3;
}

.info-cell {
  min-height: 90rpx;
  padding: 18rpx 20rpx;
  background: #f7f9fc;
}

.info-label {
  color: #8492a4;
  font-size: 21rpx;
}

.info-value {
  margin-top: 7rpx;
  color: #34465b;
  font-size: 25rpx;
  font-weight: 500;
}

.data-value {
  color: #1769aa;
  font-weight: 700;
}

.reason-section {
  margin-top: 26rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf1f5;
}

.section-label,
.ai-label {
  color: #344f69;
  font-size: 25rpx;
  font-weight: 700;
}

.section-text,
.ai-text {
  margin-top: 10rpx;
  color: #56677a;
  font-size: 25rpx;
  line-height: 1.75;
}

.ai-panel {
  margin-top: 26rpx;
  overflow: hidden;
  border: 1rpx solid #d6e6f5;
  border-radius: 16rpx;
  background: #f6faff;
}

.ai-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 23rpx 25rpx;
}

.ai-panel-title {
  color: #1769aa;
  font-size: 27rpx;
  font-weight: 700;
}

.ai-panel-tip {
  margin-top: 6rpx;
  color: #7890a8;
  font-size: 21rpx;
}

.expand-icon {
  color: #1769aa;
  font-size: 40rpx;
  line-height: 1;
  transform: rotate(0deg);
}

.expand-icon.expanded {
  transform: rotate(180deg);
}

.ai-panel-content {
  padding: 0 25rpx 25rpx;
  border-top: 1rpx solid #e2edf7;
}

.ai-section {
  margin-top: 23rpx;
}

.ai-risk {
  margin-top: 24rpx;
}

.disclaimer-box {
  margin-top: 10rpx;
}

.bottom-actions {
  position: sticky;
  bottom: 0;
  z-index: 5;
  display: flex;
  gap: 18rpx;
  margin: 30rpx -10rpx -28rpx;
  padding: 20rpx 10rpx 28rpx;
  background: linear-gradient(rgba(243, 246, 250, 0), #f3f6fa 20%);
}

.bottom-actions button {
  flex: 1;
  margin: 0;
}

.empty-match-card {
  padding: 38rpx 32rpx 34rpx;
  border-top: 6rpx solid #79a9d2;
}

.empty-match-title {
  color: #17395f;
  font-size: 36rpx;
  font-weight: 700;
}

.empty-match-description {
  margin-top: 18rpx;
  color: #5b6d81;
  font-size: 26rpx;
  line-height: 1.75;
}

.empty-section {
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 14rpx;
  background: #f6f9fc;
}

.suggestion-section {
  background: #f1f7fd;
}

.empty-section-title {
  margin-bottom: 16rpx;
  color: #344f69;
  font-size: 27rpx;
  font-weight: 700;
}

.empty-list-item {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
  color: #526377;
  font-size: 25rpx;
  line-height: 1.65;
}

.list-dot {
  flex-shrink: 0;
  width: 32rpx;
  color: #1769aa;
  font-size: 30rpx;
  line-height: 1.35;
}

.list-number {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  margin-top: 3rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #dcecf9;
  color: #1769aa;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}

.empty-disclaimer {
  margin-top: 28rpx;
}

.empty-home-button {
  width: 100%;
  margin-top: 30rpx;
}

.no-cache-card {
  margin-top: 90rpx;
}

.empty-title {
  margin-bottom: 12rpx;
  color: #34465b;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-button {
  margin-top: 40rpx;
}

