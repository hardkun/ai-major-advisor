LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# 可选：学校招生官网搜索 API。为空时不会自动搜索，不消耗额度。
# 博查 Bocha 示例：
SEARCH_PROVIDER=bocha
SEARCH_API_KEY=
SEARCH_API_URL=https://api.bochaai.com/v1/web-search
SEARCH_RESULT_LIMIT=10
SEARCH_DEBUG=false

# Serper 示例：
# SEARCH_PROVIDER=serper
# SEARCH_API_URL=https://google.serper.dev/search

# 如使用其他 POST JSON 搜索服务，可改为：
# SEARCH_PROVIDER=generic
# SEARCH_API_URL=https://example.com/search
